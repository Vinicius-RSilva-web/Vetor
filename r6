<%@page contentType="text/html" pageEncoding="UTF-8"%>
<!DOCTYPE html>
<html>
    <head>
        <meta http-equiv="Content-Type" content="text/html; charset=UTF-8">
        <title>JSP Page</title>
    </head>
    <body>
        <%  int[] valor={2,3,4,5};
        int produto = 1;
        
        for(int i=0;i<valor.length;i++){
            produto *= valor[i];
        }
        %>
        Resultado:
        <b><%= produto%></b>
    </body>
</html>
